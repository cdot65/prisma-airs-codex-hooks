{
  "name": "@cdot65/prisma-airs-codex-hooks",
  "version": "0.1.0",
  "description": "Codex CLI hooks integrating Prisma AIRS scanning into the agentic workflow",
  "type": "module",
  "keywords": [
    "codex",
    "codex-hooks",
    "openai-codex",
    "prisma",
    "airs",
    "ai-security",
    "prompt-injection",
    "dlp",
    "malicious-code",
    "palo-alto"
  ],
  "author": "cdot65",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cdot65/prisma-airs-codex-hooks.git"
  },
  "homepage": "https://cdot65.github.io/prisma-airs-codex-hooks/",
  "bugs": {
    "url": "https://github.com/cdot65/prisma-airs-codex-hooks/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.34.4",
  "bin": {
    "prisma-airs-codex-hooks": "dist/cli.js"
  },
  "files": [
    "dist/",
    "scripts/",
    "airs-config.json",
    "tsconfig.build.json",
    "src/"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json && node scripts/build-bundles.mjs",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "validate-connection": "tsx scripts/validate-connection.ts",
    "validate-detection": "tsx scripts/validate-detection.ts",
    "install-hooks": "tsx scripts/install-hooks.ts",
    "uninstall-hooks": "tsx scripts/uninstall-hooks.ts",
    "verify-hooks": "tsx scripts/verify-hooks.ts",
    "stats": "tsx scripts/airs-stats.ts",
    "docs:serve": "pnpm --filter docs-site start",
    "docs:build": "pnpm --filter docs-site build"
  },
  "dependencies": {
    "@cdot65/prisma-airs-sdk": "^0.6.7",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "0.28.1",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
